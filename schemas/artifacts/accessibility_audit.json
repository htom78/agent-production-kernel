{
  "artifact": "accessibility_audit",
  "type": "object",
  "required": [
    "version",
    "design_id",
    "wcag_level",
    "verdict",
    "checks",
    "blockers",
    "fixes_applied"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "design_id": {
      "type": "string",
      "minLength": 1
    },
    "wcag_level": {
      "type": "string",
      "enum": [
        "A",
        "AA",
        "AAA"
      ]
    },
    "verdict": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "category",
          "status",
          "evidence"
        ],
        "additionalProperties": false,
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "contrast",
              "semantic_html",
              "keyboard_focus",
              "motion_forms"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "not_applicable"
            ]
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "fixes_applied": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
