{
  "artifact": "agent_battle_harness_report",
  "type": "object",
  "required": [
    "version",
    "run_id",
    "subject",
    "input_reports",
    "protocol",
    "judges",
    "cross_examination",
    "critic_veto",
    "judge_audit",
    "outcome"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {"type": "string", "const": "1.0"},
    "run_id": {"type": "string", "minLength": 1},
    "subject": {"type": "string", "minLength": 1},
    "input_reports": {
      "type": "object",
      "required": [
        "self_assessment_report",
        "self_assessment_run_id",
        "battle_report",
        "battle_report_run_id"
      ],
      "additionalProperties": false,
      "properties": {
        "self_assessment_report": {"type": "string", "minLength": 1},
        "self_assessment_run_id": {"type": "string", "minLength": 1},
        "battle_report": {"type": "string", "minLength": 1},
        "battle_report_run_id": {"type": "string", "minLength": 1}
      }
    },
    "protocol": {
      "type": "object",
      "required": [
        "independent_contexts",
        "evidence_mode",
        "blind_review",
        "critic_veto",
        "cross_exam_rounds",
        "minimum_score_to_advance",
        "required_judges"
      ],
      "additionalProperties": false,
      "properties": {
        "evidence_mode": {"type": "string", "enum": ["derived_report", "independent_agent_reports"]},
        "independent_contexts": {"type": "boolean"},
        "blind_review": {"type": "boolean"},
        "critic_veto": {"type": "boolean"},
        "cross_exam_rounds": {"type": "integer", "minimum": 0},
        "minimum_score_to_advance": {"type": "number", "minimum": 0, "maximum": 100},
        "required_judges": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "judges": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "role",
          "input_run_id",
          "context_hash",
          "context_refs",
          "source",
          "source_report",
          "peer_scores_visible",
          "score",
          "verdict",
          "stance",
          "findings",
          "veto_vote"
        ],
        "additionalProperties": false,
        "properties": {
          "role": {"type": "string", "minLength": 1},
          "input_run_id": {"type": "string", "minLength": 1},
          "context_hash": {"type": "string", "minLength": 1},
          "context_refs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "source": {"type": "string", "enum": ["derived_battle_report", "external_agent_report"]},
          "source_report": {"type": "string", "minLength": 1},
          "peer_scores_visible": {"type": "boolean"},
          "score": {"type": "number", "minimum": 0, "maximum": 100},
          "verdict": {"type": "string", "enum": ["advance", "hold", "needs_human"]},
          "stance": {"type": "string", "minLength": 1},
          "findings": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "veto_vote": {
            "type": "object",
            "required": ["active", "reason"],
            "additionalProperties": false,
            "properties": {
              "active": {"type": "boolean"},
              "reason": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    },
    "cross_examination": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["from_role", "to_role", "challenge", "response", "status"],
        "additionalProperties": false,
        "properties": {
          "from_role": {"type": "string", "minLength": 1},
          "to_role": {"type": "string", "minLength": 1},
          "challenge": {"type": "string", "minLength": 1},
          "response": {"type": "string", "minLength": 1},
          "status": {"type": "string", "enum": ["answered", "needs_followup"]}
        }
      }
    },
    "critic_veto": {
      "type": "object",
      "required": ["enabled", "active", "reason"],
      "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean"},
        "active": {"type": "boolean"},
        "reason": {"type": "string", "minLength": 1}
      }
    },
    "judge_audit": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["check", "status", "evidence_refs"],
        "additionalProperties": false,
        "properties": {
          "check": {"type": "string", "minLength": 1},
          "status": {"type": "string", "enum": ["pass", "fail"]},
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "outcome": {
      "type": "object",
      "required": ["verdict", "score", "accepted_actions"],
      "additionalProperties": false,
      "properties": {
        "verdict": {"type": "string", "enum": ["advance", "hold", "needs_human"]},
        "score": {"type": "number", "minimum": 0, "maximum": 100},
        "accepted_actions": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "release_disciplines": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
