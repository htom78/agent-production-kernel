{
  "artifact": "autonomy_run_report",
  "type": "object",
  "required": ["version", "run_id", "selected_action", "decision", "stop_reason", "boundaries", "commands"],
  "additionalProperties": false,
  "properties": {
    "version": {"type": "string", "const": "1.0"},
    "run_id": {"type": "string", "minLength": 1},
    "selected_action": {
      "type": "object",
      "required": ["id", "title", "priority", "target_files", "verification_commands"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "priority": {"type": "string", "enum": ["P0", "P1", "P2"]},
        "target_files": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "verification_commands": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "decision": {"type": "string", "enum": ["executed", "blocked", "failed", "no_action"]},
    "stop_reason": {"type": "string", "minLength": 1},
    "boundaries": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "command",
          "status",
          "exit_code",
          "stdout_digest",
          "stderr_digest",
          "commit_sha",
          "tool_version",
          "timestamp",
          "artifact_refs"
        ],
        "additionalProperties": false,
        "properties": {
          "command": {"type": "string", "minLength": 1},
          "status": {"type": "string", "enum": ["pass", "fail", "blocked"]},
          "exit_code": {"type": "integer"},
          "stdout_digest": {"type": "string", "minLength": 1},
          "stderr_digest": {"type": "string", "minLength": 1},
          "commit_sha": {"type": "string", "minLength": 1},
          "tool_version": {"type": "string", "minLength": 1},
          "timestamp": {"type": "string", "minLength": 1},
          "artifact_refs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    }
  }
}
