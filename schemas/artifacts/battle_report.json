{
  "artifact": "battle_report",
  "type": "object",
  "required": [
    "version",
    "run_id",
    "evidence_fingerprint",
    "subject",
    "overall_score",
    "verdict",
    "judges",
    "consensus",
    "dissent",
    "next_actions",
    "release_disciplines"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {"type": "string", "const": "1.0"},
    "run_id": {"type": "string", "minLength": 1},
    "evidence_fingerprint": {"type": "string", "minLength": 1},
    "subject": {"type": "string", "minLength": 1},
    "overall_score": {"type": "number", "minimum": 0, "maximum": 100},
    "verdict": {"type": "string", "enum": ["advance", "hold", "needs_human"]},
    "judges": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role", "score", "stance", "evidence_refs", "concerns", "recommended_actions"],
        "additionalProperties": false,
        "properties": {
          "role": {"type": "string", "minLength": 1},
          "score": {"type": "number", "minimum": 0, "maximum": 100},
          "stance": {"type": "string", "minLength": 1},
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "concerns": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "recommended_actions": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "consensus": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "dissent": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "next_actions": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "release_disciplines": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
