{
  "artifact": "bug_report",
  "type": "object",
  "required": ["version", "issue_id", "observed_behavior", "expected_behavior", "reproduction_steps", "evidence"],
  "additionalProperties": false,
  "properties": {
    "version": {"type": "string", "const": "1.0"},
    "issue_id": {"type": "string", "minLength": 1},
    "observed_behavior": {"type": "string", "minLength": 1},
    "expected_behavior": {"type": "string", "minLength": 1},
    "reproduction_steps": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "evidence": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
