{
  "artifact": "design_release_report",
  "type": "object",
  "required": [
    "version",
    "design_id",
    "status",
    "gates",
    "open_decisions",
    "attribution_refs"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "design_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "ready",
        "hold"
      ]
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "status",
          "evidence_artifact"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "blocked"
            ]
          },
          "evidence_artifact": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "open_decisions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "attribution_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
