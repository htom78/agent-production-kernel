{
  "artifact": "release_report",
  "type": "object",
  "required": ["version", "release_id", "gates", "status", "rollback_plan"],
  "additionalProperties": false,
  "properties": {
    "version": {"type": "string", "const": "1.0"},
    "release_id": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["ready", "blocked", "released"]},
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "status", "evidence"],
        "additionalProperties": false,
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "status": {"type": "string", "enum": ["pass", "fail", "blocked"]},
          "evidence": {
            "type": "object",
            "required": [
              "command",
              "status",
              "exit_code",
              "stdout_digest",
              "stderr_digest",
              "commit_sha",
              "tool_version",
              "timestamp",
              "artifact_refs"
            ],
            "additionalProperties": false,
            "properties": {
              "command": {"type": "string", "minLength": 1},
              "status": {"type": "string", "enum": ["pass", "fail", "blocked"]},
              "exit_code": {"type": "integer"},
              "stdout_digest": {"type": "string", "minLength": 1},
              "stderr_digest": {"type": "string", "minLength": 1},
              "commit_sha": {"type": "string", "minLength": 1},
              "tool_version": {"type": "string", "minLength": 1},
              "timestamp": {"type": "string", "minLength": 1},
              "artifact_refs": {
                "type": "array",
                "minItems": 1,
                "items": {"type": "string", "minLength": 1}
              }
            }
          }
        }
      }
    },
    "rollback_plan": {"type": "string", "minLength": 1}
  }
}
