{
  "artifact": "self_assessment_report",
  "type": "object",
  "required": [
    "version",
    "run_id",
    "evidence_fingerprint",
    "overall_score",
    "decision",
    "dimensions",
    "commands",
    "next_actions"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {"type": "string", "const": "1.0"},
    "run_id": {"type": "string", "minLength": 1},
    "evidence_fingerprint": {"type": "string", "minLength": 1},
    "overall_score": {"type": "number", "minimum": 0, "maximum": 100},
    "decision": {"type": "string", "enum": ["continue", "hold", "needs_human"]},
    "dimensions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "score", "rationale", "evidence_refs"],
        "additionalProperties": false,
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "score": {"type": "number", "minimum": 0, "maximum": 100},
          "rationale": {"type": "string", "minLength": 1},
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "command",
          "status",
          "exit_code",
          "stdout_digest",
          "stderr_digest",
          "commit_sha",
          "tool_version",
          "timestamp",
          "artifact_refs"
        ],
        "additionalProperties": false,
        "properties": {
          "command": {"type": "string", "minLength": 1},
          "status": {"type": "string", "enum": ["pass", "fail", "blocked"]},
          "exit_code": {"type": "integer"},
          "stdout_digest": {"type": "string", "minLength": 1},
          "stderr_digest": {"type": "string", "minLength": 1},
          "commit_sha": {"type": "string", "minLength": 1},
          "tool_version": {"type": "string", "minLength": 1},
          "timestamp": {"type": "string", "minLength": 1},
          "artifact_refs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "priority",
          "rationale",
          "target_files",
          "verification_commands"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "priority": {"type": "string", "enum": ["P0", "P1", "P2"]},
          "rationale": {"type": "string", "minLength": 1},
          "target_files": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "verification_commands": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    }
  }
}
