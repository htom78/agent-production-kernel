{
  "artifact": "source_evidence",
  "type": "object",
  "required": ["version", "question_id", "sources", "coverage_notes"],
  "additionalProperties": false,
  "properties": {
    "version": {"type": "string", "const": "1.0"},
    "question_id": {"type": "string", "minLength": 1},
    "coverage_notes": {"type": "string", "minLength": 1},
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "claim", "reliability", "citation"],
        "additionalProperties": false,
        "properties": {
          "title": {"type": "string", "minLength": 1},
          "claim": {"type": "string", "minLength": 1},
          "reliability": {"type": "string", "enum": ["low", "medium", "high"]},
          "citation": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
