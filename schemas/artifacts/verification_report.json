{
  "artifact": "verification_report",
  "type": "object",
  "required": ["version", "issue_id", "overall_status", "commands"],
  "additionalProperties": false,
  "properties": {
    "version": {"type": "string", "const": "1.0"},
    "issue_id": {"type": "string", "minLength": 1},
    "overall_status": {"type": "string", "enum": ["pass", "fail", "blocked"]},
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "command",
          "status",
          "exit_code",
          "stdout_digest",
          "stderr_digest",
          "commit_sha",
          "tool_version",
          "timestamp",
          "artifact_refs"
        ],
        "additionalProperties": false,
        "properties": {
          "command": {"type": "string", "minLength": 1},
          "status": {"type": "string", "enum": ["pass", "fail", "blocked"]},
          "exit_code": {"type": "integer"},
          "stdout_digest": {"type": "string", "minLength": 1},
          "stderr_digest": {"type": "string", "minLength": 1},
          "commit_sha": {"type": "string", "minLength": 1},
          "tool_version": {"type": "string", "minLength": 1},
          "timestamp": {"type": "string", "minLength": 1},
          "artifact_refs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    }
  }
}
